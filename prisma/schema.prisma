  id         String @id @default(cuid())
  businessId String
  sourceType String
  filePath   String?
  status     String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  cashflows Cashflow[]
  productTransactions ProductTransaction[]
}

