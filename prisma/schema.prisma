// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id           String @id @default(cuid())
  userId       String
  businessName String
  businessType String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  cashflows          Cashflow[]
  products           Product[]
  productTransactions ProductTransaction[]
  stockMovements     StockMovement[]
  inputBatches       InputBatch[]
  dailyMetrics       DailyMetric[]
  stockSnapshots     StockSnapshot[]
}

model CashflowCategory {
  id         String @id @default(cuid())
  categoryName String

  cashflows Cashflow[]
}

model Cashflow {
  id             String    @id @default(cuid())
  businessId     String
  categoryId     String
  transactionDate DateTime @db.Date
  cashflowType   String
  amount         Decimal @db.Decimal(18,2)
  description    String?
  sourceBatchId  String?
  createdAt      DateTime @default(now())

  business     Business         @relation(fields: [businessId], references: [id])
  category     CashflowCategory @relation(fields: [categoryId], references: [id])
  sourceBatch  InputBatch?      @relation(fields: [sourceBatchId], references: [id])
}

model Product {
  id           String @id @default(cuid())
  businessId   String
  productName  String
  category     String
  unit         String
  defaultCost  Decimal @db.Decimal(18,2)
  defaultPrice Decimal @db.Decimal(18,2)
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  productTransactions ProductTransaction[]
  stockMovements     StockMovement[]
  stockSnapshots     StockSnapshot[]
}

model ProductTransaction {
  id               String @id @default(cuid())
  businessId       String
  productId        String
  transactionDate  DateTime @db.Date
  transactionType  String
  quantity         Decimal @db.Decimal(18,2)
  price            Decimal @db.Decimal(18,2)
  total            Decimal @db.Decimal(18,2) // Computed in SQL, handled as regular field in Prisma
  sourceBatchId    String?

  business    Business @relation(fields: [businessId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  sourceBatch InputBatch? @relation(fields: [sourceBatchId], references: [id])
}

model StockMovement {
  id                String @id @default(cuid())
  businessId        String
  productId         String
  movementDate      DateTime @db.Date
  quantityChange    Decimal @db.Decimal(18,2)
  reason            String
  sourceTransaction String? // References ProductTransaction.id
  createdAt         DateTime @default(now())

  product             Product           @relation(fields: [productId], references: [id])
  business            Business          @relation(fields: [businessId], references: [id])
  productTransaction  ProductTransaction? @relation(fields: [sourceTransaction], references: [id])
}

model InputBatch {
  id         String @id @default(cuid())
  businessId String
  sourceType String
  filePath   String?
  status     String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  cashflows Cashflow[]
  productTransactions ProductTransaction[]
}

model DailyMetric {
  id              String @id @default(cuid())
  businessId      String
  date            DateTime @unique @db.Date
  totalIncome     Decimal @db.Decimal(18,2)
  totalExpense    Decimal @db.Decimal(18,2)
  netCash         Decimal @db.Decimal(18,2)
  totalStockValue Decimal @db.Decimal(18,2)
  abnormalFlag    Boolean @default(false)
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model StockSnapshot {
  id           String @id @default(cuid())
  businessId   String
  productId    String
  snapshotDate DateTime @db.Date
  stockQty     Decimal @db.Decimal(18,2)

  business Business @relation(fields: [businessId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model Business {
  id           String @id @default(cuid())
  userId       String
  businessName String
  businessType String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  cashflows          Cashflow[]
  products           Product[]
  productTransactions ProductTransaction[]
  stockMovements     StockMovement[]
  inputBatches       InputBatch[]
  dailyMetrics       DailyMetric[]
  stockSnapshots     StockSnapshot[]
}

